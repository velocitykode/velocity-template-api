# App
APP_NAME=Velocity
APP_ENV=development
APP_URL=http://localhost:4000
APP_PORT=4000
# CORS: comma-separated origins allowed to make credentialed cross-origin
# requests. NEVER use "*" with credentials. Set this to your frontend
# origin(s); falls back to APP_URL when unset.
CORS_ALLOWED_ORIGINS=http://localhost:4000

# Logging
LOG_DRIVER=console
LOG_LEVEL=info

# Encryption & signing - the installer populates these with random
# 32-byte base64 values at install time. APP_KEY is also the crypto
# fallback; set CRYPTO_KEY explicitly only if you want a dedicated
# crypto key separate from APP_KEY.
#
# APP_KEY MUST carry the "base64:" prefix so velocity/crypto base64-
# decodes it back to the 32 raw bytes the AES driver requires. Use
# `vel key:generate` to (re)mint it; pasting a raw base64 value
# without the prefix will fail boot with ErrInvalidKeyLength.
# QUEUE_SIGNING_KEY and AUTH_JWT_SECRET are consumed as raw HMAC
# bytes and stay unprefixed.
APP_KEY=
QUEUE_SIGNING_KEY=
AUTH_JWT_SECRET=
CRYPTO_CIPHER=AES-256-CBC

# Enable to revoke blacklisted JWT IDs.
AUTH_JWT_BLACKLIST_ENABLED=false

# Database
DB_CONNECTION=sqlite
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=database.sqlite
DB_USERNAME=
DB_PASSWORD=
# DB_SSL_MODE=disable

# Cache
CACHE_DRIVER=memory

# Session (for stateful API auth)
SESSION_NAME=velocity_session
SESSION_LIFETIME=120
SESSION_PATH=/
SESSION_DOMAIN=
SESSION_SECURE=false
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax

# Authentication
AUTH_GUARD=api
AUTH_MODEL=User

# Filesystem
FILESYSTEM_DISK=local

# gRPC (optional, only used when grpc.NewServer is wired in main.go)
# GRPC_PORT=50051
# GRPC_REFLECTION=false
# GRPC_MAX_RECV_SIZE=4194304
# GRPC_MAX_SEND_SIZE=4194304

# gRPC Gateway (HTTP/JSON to gRPC bridge)
# GATEWAY_PORT=8080
# GRPC_ENDPOINT=localhost:50051

# JWT tuning (secret + blacklist flag live at the top of this file).
# AUTH_JWT_TTL=60
# AUTH_JWT_REFRESH_TTL=20160
